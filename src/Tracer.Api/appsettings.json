{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "TracerDb": "",
    "ServiceBus": ""
  },
  "Providers": {
    "Ares": {
      "BaseUrl": "https://ares.gov.cz/ekonomicke-subjekty-v-be/rest",
      "TimeoutSeconds": 10
    },
    "CompaniesHouse": {
      "BaseUrl": "https://api.company-information.service.gov.uk",
      "ApiKey": "",
      "TimeoutSeconds": 10,
      "RateLimitPerFiveMin": 600
    },
    "GleifLei": {
      "BaseUrl": "https://api.gleif.org/api/v1",
      "TimeoutSeconds": 10
    },
    "GoogleMaps": {
      "ApiKey": "",
      "TimeoutSeconds": 5
    },
    "AzureMaps": {
      "ApiKey": "",
      "TimeoutSeconds": 10
    },
    "BrazilCnpj": {
      "BaseUrl": "https://brasilapi.com.br/api/",
      "TimeoutSeconds": 10
    },
    "StateSos": {
      "MaxRequestsPerMinute": 20,
      "TimeoutSeconds": 12,
      "SupportedStates": ["CA", "DE", "NY"]
    },
    "Handelsregister": {
      "BaseUrl": "https://www.handelsregister.de/rp_web/",
      "MaxRequestsPerHour": 60,
      "TimeoutSeconds": 12
    },
    "AzureOpenAI": {
      "Endpoint": "",
      "ApiKey": "",
      "DeploymentName": "gpt-4o-mini",
      "MaxTokens": 2000
    }
  },
  "Revalidation": {
    "Enabled": true,
    "IntervalMinutes": 60,
    "MaxProfilesPerRun": 100,
    "FieldTtl": {
      "EntityStatus": "30.00:00:00",
      "Officers": "90.00:00:00",
      "Phone": "180.00:00:00",
      "Email": "180.00:00:00",
      "RegisteredAddress": "365.00:00:00",
      "RegistrationId": "730.00:00:00",
      "TaxId": "730.00:00:00",
      "LegalForm": "730.00:00:00"
    }
  },
  "ServiceBus": {
    "RequestQueue": "tracer-request",
    "ResponseQueue": "tracer-response",
    "ChangesTopic": "tracer-changes"
  },
  "Gdpr": {
    "PersonalDataRetentionDays": 1095,
    "AuditPersonalDataAccess": true
  },
  "Auth": {
    "ApiKeys": []
  }
}
